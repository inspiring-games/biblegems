{
  "name": "Report",
  "type": "object",
  "properties": {
    "reporter_id": {
      "type": "string",
      "description": "ID of the reporting user"
    },
    "target_type": {
      "type": "string",
      "enum": [
        "gem",
        "user"
      ],
      "description": "Type of reported content"
    },
    "target_id": {
      "type": "string",
      "description": "ID of the reported gem or user"
    },
    "reason": {
      "type": "string",
      "description": "Reason for the report"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "reviewed",
        "resolved",
        "dismissed"
      ],
      "default": "pending"
    },
    "admin_notes": {
      "type": "string",
      "description": "Notes from admin review"
    }
  },
  "required": [
    "reporter_id",
    "target_type",
    "target_id",
    "reason"
  ]
}